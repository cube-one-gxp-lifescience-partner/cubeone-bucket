{
    "version": "16.0.19725.20170",
    "description": "Family of client software, server software and services developed by Microsoft.",
    "homepage": "https://www.office.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.microsoft.com/licensing/terms/productoffering/OfficeDesktopApplicationsWindows/MCA"
    },
    "depends": "7zip19.00-helper",
    "url": "https://download.microsoft.com/download/6c1eeb25-cf8b-41d9-8d0d-cc1dbc032140/officedeploymenttool_19725-20126.exe#/dl.7z_",
    "hash": "c4f7e338848649d0d73becbfcc02b1f4616a0e66a11bbd286fabb4eb58e769b4",
    "installer": {
        "script": [
            "Start-Process -Wait 7z1900-helper -ArgumentList @('x', '-bso0', \"`\"$dir\\dl.7z_`\"\", \"`\"-o$dir`\"\")",
            "$client = if ($architecture -eq '32bit') { '32' } else { '64' }",
            "$utf8NoBom = New-Object System.Text.UTF8Encoding $false",
            "$installXml = '<Configuration><Add OfficeClientEdition=\"' + $client + '\" Channel=\"Current\"><Product ID=\"O365BusinessRetail\"><Language ID=\"MatchOS\" /></Product></Add><Display Level=\"Basic\" AcceptEULA=\"TRUE\" /></Configuration>'",
            "[System.IO.File]::WriteAllText(\"$dir\\ms-office.xml\", $installXml, $utf8NoBom)",
            "$uninstallXml = '<Configuration><Remove All=\"TRUE\" /><Display Level=\"None\" AcceptEULA=\"TRUE\" /></Configuration>'",
            "[System.IO.File]::WriteAllText(\"$dir\\uninstall-ms-office.xml\", $uninstallXml, $utf8NoBom)",
            "[System.IO.File]::WriteAllText(\"$dir\\install-office.bat\", '\"%~dp0setup.exe\" /configure \"%~dp0ms-office.xml\"', $utf8NoBom)",
            "[System.IO.File]::WriteAllText(\"$dir\\uninstall-office.bat\", '\"%~dp0setup.exe\" /configure \"%~dp0uninstall-ms-office.xml\"', $utf8NoBom)",
            "$officeReg = 'HKLM:\\SOFTWARE\\Microsoft\\Office\\ClickToRun\\Configuration'",
            "$productIds = if (Test-Path $officeReg) { (Get-ItemProperty $officeReg -ErrorAction SilentlyContinue).ProductReleaseIds } else { $null }",
            "if ($productIds -and $productIds -notlike '*O365Business*') {",
            "    Write-Host \"Inkompatible Office-Installation gefunden ($productIds) - wird entfernt...\"",
            "    $p = Start-Process -PassThru -Verb RunAs -FilePath 'cmd.exe' -ArgumentList \"/c `\"$dir\\uninstall-office.bat`\"\"",
            "    $p.WaitForExit()",
            "}",
            "$p = Start-Process -PassThru -Verb RunAs -FilePath 'cmd.exe' -ArgumentList \"/c `\"$dir\\install-office.bat`\"\"",
            "$p.WaitForExit()",
            "New-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'OneDrive' -Value '\"%LOCALAPPDATA%\\Microsoft\\OneDrive\\OneDrive.exe\" /background' -PropertyType String -Force | Out-Null",
            "$odPolicyPath = 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\OneDrive'",
            "New-Item -Path $odPolicyPath -Force | Out-Null",
            "New-ItemProperty -Path $odPolicyPath -Name 'KFMSilentOptIn' -Value '4eeeffad-35f0-4ce5-b7d4-1aa5693e50ce' -PropertyType String -Force | Out-Null",
            "New-ItemProperty -Path $odPolicyPath -Name 'KFMSilentOptInWithNotification' -Value 1 -PropertyType DWord -Force | Out-Null",
            "New-ItemProperty -Path $odPolicyPath -Name 'KFMSilentOptInDesktop' -Value 1 -PropertyType DWord -Force | Out-Null",
            "New-ItemProperty -Path $odPolicyPath -Name 'KFMSilentOptInDocuments' -Value 1 -PropertyType DWord -Force | Out-Null",
            "New-ItemProperty -Path $odPolicyPath -Name 'KFMSilentOptInPictures' -Value 1 -PropertyType DWord -Force | Out-Null",
            "$tenantMountPath = 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\OneDrive\\TenantAutoMount'",
            "New-Item -Path $tenantMountPath -Force | Out-Null",
            "$libraryId = 'tenantId=4eeeffad%2D35f0%2D4ce5%2Db7d4%2D1aa5693e50ce&siteId=%7B087c95da%2D4184%2D4e10%2D8ffb%2D3f75bff0d621%7D&webId=%7Bfd09b123%2D2ddb%2D4821%2D8f4d%2D483d2178efd4%7D&listId=fd3d62b9%2D38bc%2D4d2d%2D8fb8%2D23e2efcc1c49&webUrl=https%3A%2F%2Fcubeonegxp%2Esharepoint%2Ecom&version=1'",
            "New-ItemProperty -Path $tenantMountPath -Name 'SharePointSiteName' -Value $libraryId -PropertyType String -Force | Out-Null"
        ]
    },
    "pre_uninstall": [
        "$utf8NoBom = New-Object System.Text.UTF8Encoding $false",
        "$uninstallXml = '<Configuration><Remove All=\"TRUE\" /><Display Level=\"None\" AcceptEULA=\"TRUE\" /></Configuration>'",
        "[System.IO.File]::WriteAllText(\"$dir\\uninstall-ms-office.xml\", $uninstallXml, $utf8NoBom)",
        "[System.IO.File]::WriteAllText(\"$dir\\uninstall-office.bat\", '\"%~dp0setup.exe\" /configure \"%~dp0uninstall-ms-office.xml\"', $utf8NoBom)"
    ],
    "uninstaller": {
        "script": [
            "$p = Start-Process -PassThru -Verb RunAs -FilePath 'cmd.exe' -ArgumentList \"/c `\"$dir\\uninstall-office.bat`\"\"",
            "$p.WaitForExit()"
        ]
    },
    "checkver": {
        "script": [
            "$ProgressPreference = 'SilentlyContinue'",
            "$url1 = 'https://docs.microsoft.com/en-us/officeupdates/odt-release-history'",
            "$regex1 = '<p>Version ([\\d.]+)'",
            "$url2 = 'https://www.microsoft.com/en-us/download/details.aspx?id=49117'",
            "$regex2 = 'download/([\\w/-]+)(officedeploymenttool_[\\d-]+\\.exe)'",
            "",
            "$cont = $(Invoke-WebRequest $url1).Content",
            "if (!($cont -match $regex1)) { Write-Host \"Could not match '$regex1' in '$url1'\"; return }",
            "$app_ver = $matches[1]",
            "$cont = $(Invoke-WebRequest $url2).Content",
            "if (!($cont -match $regex2)) { Write-Host \"Could not match '$regex2' in '$url2'\"; return }",
            "$path = $matches[1]; $filename = $matches[2]",
            "Write-Output $app_ver $path $filename"
        ],
        "regex": "([\\d.]+) (?<path>[\\w-/]+) (?<filename>[\\w.-]+)"
    },
    "autoupdate": {
        "url": "https://download.microsoft.com/download/$matchPath$matchFilename#/dl.7z_"
    }
}
