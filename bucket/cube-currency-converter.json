{
    "version": "1.0.0",
    "description": "CubeCurrencyConverter - Currency converter from cube one",
    "homepage": "https://cubeone.de",
    "license": "Proprietary",
    "url": "https://httpbin.org/robots.txt",
    "bin": "CubeCurrencyConverter.exe",
    "shortcuts": [
        [
            "CubeCurrencyConverter.exe",
            "CubeCurrencyConverter"
        ]
    ],
    "pre_install": [
        "Remove-Item \"$dir\\robots.txt\" -ErrorAction SilentlyContinue",
        "",
        "if (-not $env:AUTO_UPDATER_API_KEY) {",
        "    throw 'AUTO_UPDATER_API_KEY environment variable not set'",
        "}",
        "",
        "Write-Host 'Downloading CubeCurrencyConverter from cube one update server...' -ForegroundColor Blue",
        "",
        "$headers = @{",
        "    'X-API-Key' = $env:AUTO_UPDATER_API_KEY",
        "    'User-Agent' = 'cube-one-auto-updater/1.0'",
        "}",
        "",
        "$downloadUrl = 'https://update.cubeone.de/files/a40928db-d4d6-4652-9634-745ac5c044f4'",
        "$downloadPath = \"$cachedir\\CubeCurrencyConverter.zip\"",
        "",
        "try {",
        "    Invoke-WebRequest -Uri $downloadUrl -Headers $headers -OutFile $downloadPath -TimeoutSec 60",
        "",
        "    if (-not (Test-Path $downloadPath)) {",
        "        throw 'Downloaded file not found'",
        "    }",
        "",
        "    $fileInfo = Get-Item $downloadPath",
        "    Write-Host \"Download successful: $($fileInfo.Length) bytes\" -ForegroundColor Green",
        "",
        "    $expectedHash = '145EB43CFE0326183B8C9C8556C96BC0D420DBC5230985E64497372D0C7513C6'",
        "    $actualHash = (Get-FileHash -Path $downloadPath -Algorithm SHA256).Hash",
        "    if ($actualHash -ne $expectedHash) {",
        "        throw \"SHA256 hash mismatch for CubeCurrencyConverter_v1.zip. Expected: $expectedHash, Actual: $actualHash\"",
        "    }",
        "    Write-Host 'SHA256 hash verified for CubeCurrencyConverter_v1.zip' -ForegroundColor Green",
        "",
        "    $bytes = [System.IO.File]::ReadAllBytes($downloadPath)",
        "    if ($bytes[0] -ne 0x50 -or $bytes[1] -ne 0x4B) {",
        "        throw 'Downloaded file is not a valid ZIP archive'",
        "    }",
        "} catch {",
        "    throw \"Failed to download CubeCurrencyConverter: $($_.Exception.Message)\"",
        "}",
        "",
        "Write-Host 'Extracting CubeCurrencyConverter...' -ForegroundColor Blue",
        "try {",
        "    Expand-Archive -Path $downloadPath -DestinationPath $dir -Force",
        "    Write-Host 'Extraction successful' -ForegroundColor Green",
        "} catch {",
        "    throw \"Failed to extract ZIP: $($_.Exception.Message)\"",
        "}",
        "",
        "Remove-Item $downloadPath -ErrorAction SilentlyContinue"
    ],
    "post_install": [
        "if (Test-Path \"$dir\\CubeCurrencyConverter.exe\") {",
        "    $fileInfo = Get-Item \"$dir\\CubeCurrencyConverter.exe\"",
        "    Write-Host \"CubeCurrencyConverter.exe ready ($($fileInfo.Length) bytes)\" -ForegroundColor Green",
        "} else {",
        "    Write-Host 'CubeCurrencyConverter.exe not found after extraction:' -ForegroundColor Red",
        "    Get-ChildItem \"$dir\" -Recurse | ForEach-Object {",
        "        Write-Host \"  - $($_.FullName.Replace($dir, '').TrimStart('\\\\'))\" -ForegroundColor Gray",
        "    }",
        "    throw 'CubeCurrencyConverter.exe not found'",
        "}",
        "",
        "Write-Host 'CubeCurrencyConverter installed successfully!' -ForegroundColor Green"
    ],
    "notes": [
        "Portable application from cube one GmbH",
        "Downloaded from update.cubeone.de",
        "Requires AUTO_UPDATER_API_KEY environment variable for authentication",
        "Contains CubeCurrencyConverter.exe, CubeCurrencyConverter.dll, CubeCurrencyConverter.runtimeconfig.json",
        "SHA256 hash verified for CubeCurrencyConverter_v1.zip after download"
    ]
}
